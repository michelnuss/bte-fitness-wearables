# Copy this file to `.env` and fill in your values (never commit `.env`).
# Get the endpoint and agent ID from Azure AI Foundry → your project.

AZURE_AI_ENDPOINT=https://YOUR_RESOURCE.services.ai.azure.com/api/projects/YOUR_PROJECT_NAME
AZURE_AGENT_ID=asst_YOUR_AGENT_ID

# Optional: only if you add features that use a subscription key (not used by the current chat code).
# AZURE_AI_KEY=
